msgstr "डिलिव्हरी अयशस्वी"

msgid "Order Cancelled"
msgstr "ऑर्डर रद्द झाली"

msgid "Download Invoice PDF"
msgstr "इनव्हॉइस PDF डाउनलोड करा"

msgid "Cancel Order"
msgstr "ऑर्डर रद्द करा"

msgid "Are you sure you want to cancel this order?"
msgstr "तुम्हाला ही ऑर्डर रद्द करायची आहे का?"

msgid "This action cannot be undone."
msgstr "ही क्रिया मागे घेता येणार नाही"

msgid "No"
msgstr "नाही"

msgid "Yes, Cancel"
msgstr "होय, रद्द करा"

msgid "Cancellation & Refund Policy"
msgstr "रद्द करण्याचे व परताव्याचे नियम"

msgid "Order can be cancelled before it is shipped."
msgstr "ऑर्डर पाठवण्यापूर्वी रद्द करता येते."

msgid "Full refund for UPI payments if cancelled before dispatch."
msgstr "डिस्पॅचपूर्वी रद्द केल्यास UPI पेमेंटचा पूर्ण परतावा मिळेल."

msgid "If cancelled after dispatch, delivery charges may be deducted."
msgstr "डिस्पॅचनंतर रद्द केल्यास डिलिव्हरी शुल्क वजा होऊ शकते."

msgid "Refusal at delivery may result in COD restriction."
msgstr "डिलिव्हरी नाकारल्यास COD सुविधा बंद केली जाऊ शकते."

msgid "Refunds for UPI may take 3-5 working days."
msgstr "UPI परतावा 3-5 कामकाजाच्या दिवसांत मिळू शकतो."

msgid "I agree to the cancellation and refund policy."
msgstr "मी रद्द करण्याच्या व परताव्याच्या नियमांना सहमत आहे."

